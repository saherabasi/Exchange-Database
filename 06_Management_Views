-- اضافه کردن ستون نوع اعلان به جدول اعلان‌ها
----------------------------------------
alter table notifications add NotificationType nvarchar(20)

----------------------------------------

-- =============================================
-- لیست اعلان‌های کاربران
-- شامل: نوع اعلان + وضعیت خوانده‌شده (فارسی)
-- =============================================
create view mgmt.Vw_NotificationsList
as
select 
n.NotificationID,
u.UserID,
u.UserName,
dp.DepartmentID,
dp.DepartmentName,
n.NotificationType,
n.Title,
n.Description,
n.CreateDate,
n.IsRead,
case 
when n.Isread = 1 then'خوانده شده'
else 'نخوانده'
end'IsReadStatusFa'
from
Notifications n
left join
users u on n.UserID = u.UserID
left join 
Departments dp on n.DepartmentID = dp.DepartmentID
go

-- =============================================
-- گزارش تغییرات تبدیل‌های ارزی (لاگ)
-- شامل: نام مشتری + نام دپارتمان + قیمت مبدا/مقصد
-- =============================================
create view mgmt.Vw_ExchangeLogReport
as
select 
el.ExchangeLogID,
el.ExchangeID,
el.CoustomerID,
c.FirstName + ' ' + c.LastName as CustomerName,
el.DepartmentID,
dp.DepartmentName,
el.SourcePrice,
el.TargetPrice,
el.Description,
el.Type,
el.UpdateDate
from
ExchangeLog el
inner join 
Customers c on el.CoustomerID = c.CustomerID
left join 
Departments dp on el.DepartmentID = dp.DepartmentID
go

-- =============================================
-- گزارش تغییرات حواله‌ها (لاگ)
-- شامل: همه ستون‌های اصلی حواله + تاریخ بروزرسانی
-- =============================================
create or alter view mgmt.Vw_BillsLogReport
as
select
    BillsLogID,
    BillID,
    CityID,
    CountryID,
    Amount,
    SourceCustomerID,
    SourceDepartmentID,
    TargetCustomerID,
    TargetDepartmentID,
    Status,
    Description,
    ExchangeID,
    CurrencyID,
    CurrencyTypeID,
    UpdateDate
from 
    BillsLog;
go

-- =============================================
-- ترکیب اطلاعات تمام مشتریان و کاربران
-- شامل: نوع شخص + نام + ایمیل + شماره تماس + تاریخ ثبت‌نام
-- =============================================
create view mgmt.Vw_AllUserAndCustomerInfo
as 
select 
'مشتری حضوری' as UserType,
c.CustomerID as ID,
c.FirstName + ' ' + c.LastName as FullName,
c.Email,
c.PhoneNumber,
c.RegisterDate
from Customers c
union all
select 
'کاربر سایت' as UserType,
u.UserID as ID,
u.FirstName + ' ' + u.LastName as FullName,
u.Email,
u.PhoneNumber,
u.RegisterDate
from Users u
go
