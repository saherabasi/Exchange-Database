-- =============================================
-- نمایش کاربران با نقش‌هایشان
-- شامل: نام کاربر + نام نقش
-- =============================================
create view mgmt.Vw_UserRolesFull
as
select 
ur.UserRoleID,
u.FirstName + ' ' + u.LastName as UserFullName,
u.UserName,
r.RoleName
from
UserRoles ur
inner join 
Users u on ur.UserID = u.UserID
inner join 
Roles r on ur.RoleID = r.RoleID
go

-- =============================================
-- گزارش نشست‌های کاربران (ورود و خروج)
-- شامل: زمان شروع + زمان پایان نشست
-- =============================================
create view mgmt.Vw_UsersessionReport
as
select 
us.UserSessionID,
u.UserID,
u.FirstName + ' ' + u.LastName as UserFullName,
u.UserName,
us.StartSession,
us.EndSession
from 
UserSessions us 
inner join 
users u on us.UserID = u.UserID
go

-- =============================================
-- کاربران در انتظار تأیید کد فعال‌سازی
-- فقط کدهایی که هنوز معتبر هستند (منقضی نشده)
-- شامل: وضعیت فارسی (معتبر/منقضی شده)
-- =============================================
create view mgmt.Vw_PendingVerifications
as
select 
ucc.UserConfirmCodeID,
u.UserID,
u.FirstName + ' ' + u.LastName as UserFullName,
u.UserName,
ucc.Code,
ucc.ExpireDate,
case 
when ucc.ExpireDate < GETDATE() then 'منقضی شده' 
else'معتبر'
end 'ExpireStatusFa'
from 
UserConfirmCodes ucc
inner join 
Users u on ucc.UserID = u.UserID
where ucc.ExpireDate > GETDATE()
go

-- =============================================
-- گزارش تغییرات پروفایل کاربران (لاگ)
-- شامل: اطلاعات قدیمی کاربر + شهر + آی‌پی
-- =============================================
create view mgmt.Vw_UserLogsReport
as
select 
ul.UserLogID,
ul.UserID,
c.CityName,
ul.FirstName,
ul.LastName,
ul.UserName,
ul.HashPassword,
ul.Email,
ul.PhoneNumber,
ul.Address,
ul.createDate,
ul.ClientIP
from
UserLog ul 
left join 
Cities c on ul.CityID = c.CityID
go


