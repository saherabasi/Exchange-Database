-- =============================================
-- موجودی کل یک مشتری در یک ارز خاص
-- ورودی: شناسه مشتری + نوع ارز
-- خروجی: مجموع موجودی
-- =============================================
create or alter function fn_GetCustomerTotalBalnce(@CustomerID int , @Currency nvarchar(20))
returns decimal(18,2)
as begin
return(
select isnull(sum(a.Balance),0) from Accounts a 
where a.CustomerID = @CustomerID and a.Currency = @Currency
)
end
go

-- =============================================
-- آخرین نرخ تبدیل دو ارز
-- ورودی: ارز مبدا + ارز مقصد
-- خروجی: آخرین نرخ فعال
-- =============================================
create or alter function fn_GetExchangeRate(@FromCurrency nvarchar(20),@ToCurrency nvarchar(20))
returns decimal(18,2)
as begin
return(
	select top(1) isnull(er.Rate,0) from ExchangeRates er 
	where FromCurrency = @FromCurrency and ToCurrency = @ToCurrency
	order by er.RateDate desc
	)
end
go

-- =============================================
-- سود کل امروز صرافی
-- ورودی: ندارد
-- خروجی: جمع سود تمام تراکنش‌های امروز
-- =============================================
create function fn_GetDailyProfit()
returns decimal(18,2)
as begin
	return(
		select isnull(sum(Profit),0) from Transactions 
		where cast(TransactionDate as date) = cast(GETDATE() as date)
	)
end
go

-- =============================================
-- مجموع وام‌های فعال یک مشتری
-- ورودی: شناسه مشتری
-- خروجی: جمع مبالغ وام‌های فعال
-- =============================================
create function fn_GetCustomerTotalLoan(@CustomerID int)
returns decimal(18,2)
as begin
	return(
		select sum(cl.AmountLoan) 
		from 
		CustomerLoans cl
		inner join
		Accounts a on cl.AccountID = a.AccountID
		where a.CustomerID = @CustomerID and cl.Status = 'Active'
	)
end
go

