create function fn_GetUserUnreadNotifications(@UserID int)
returns int
as begin
	return(
		select count(*) from Notifications n
		where n.UserID = @UserID and n.IsRead != 1
	)
end
go

-- =============================================
-- تشخیص VIP بودن مشتری بر اساس گردش مالی
-- ۱۰ مشتری برتر = VIP
-- ورودی: شناسه مشتری
-- خروجی: vip هست / vip نیست
-- =============================================
create function fn_IsCustomerVIP(@CustomerID int)
returns nvarchar(20)
as begin
	declare @res nvarchar(10) = 'vip نیست '
	
	if exists (
		select 1 from (
		select top(10)
		a.CustomerID,
		sum(Amount) as totalAmount,
		sum(profit) as totalProfit
		from Transactions t 
		inner join Accounts a on t.AccountID = a.AccountID
		group by CustomerID
		order by totalAmount desc,totalProfit desc
		)as top10
		where top10.CustomerID = @CustomerID
	)
	set @res = 'vip هست'
	return @res
end
go

-- =============================================
-- رتبه‌بندی مشتری (طلایی/نقره‌ای/برنزی/عادی)
-- بر اساس مجموع تراکنش‌ها
-- ورودی: شناسه مشتری
-- خروجی: عنوان رتبه
-- =============================================
create function fn_GetCustomerRank(@CustomerID int)
returns nvarchar(20)
as begin
	declare @rank int
	declare @res nvarchar(20) = 'عضو عادی'
	;with cte as(
		select
		a.CustomerID,
		sum(t.Amount) as totalAmount,
		row_number() over (order by sum(t.Amount) desc) as RankNum
		from
		Transactions t inner join Accounts a on t.AccountID = a.AccountID
		GROUP by a.CustomerID
	)
	select @rank = RankNum from cte where cte.CustomerID = @CustomerID
	if @rank between 1 and 3 set @res = 'عضو طلایی'
	if @rank between 4 and 6 set @res = 'عضو نقره ای'
	if @rank between 7 and 10 set @res = 'عضو برنزی'
	return @res
end
go

