-- =============================================
-- محاسبه کارمزد تراکنش
-- ورودی: مبلغ تراکنش + درصد کارمزد
-- خروجی: مبلغ کارمزد
-- =============================================
create function fn_CalcCommision(
@Amount decimal(18,2),
@CommisionRate decimal(5,2))
returns decimal(18,2)
as begin
	return (@Amount * @CommisionRate)/100
end
go

-- =============================================
-- محاسبه مبلغ هر قسط وام
-- ورودی: مبلغ وام + تعداد اقساط + درصد بهره
-- خروجی: مبلغ هر قسط
-- =============================================
create function fn_GetInstallmentAmount(@Amount decimal(18,2),@InstallmentCount int,@IntrestLoan decimal(5,2))
returns decimal(18,2)
as begin
	declare @intrest decimal(18,2) = (select dbo.fn_CalcCommision(@Amount,@IntrestLoan))
	If @InstallmentCount = 0 return 0
	return (@Amount + @intrest) / @InstallmentCount 
end
go

-- =============================================
-- محاسبه سن دقیق از تاریخ تولد
-- ورودی: تاریخ تولد
-- خروجی: سن به سال
-- =============================================
create or alter function fn_GetAge(@BirthDate date)
returns int
as begin
	return(
		datediff(YEAR,@BirthDate,getdate()) - 
		case 
		when dateadd(year,datediff(YEAR,@BirthDate,getdate()),@BirthDate) > getdate()
		then 1 else 0 end
	)
end
go

-- =============================================
-- بررسی وضعیت انقضای کارت بانکی
-- ورودی: تاریخ انقضا
-- خروجی: معتبر / منقضی شده / در حال انقضا / نامشخص
-- =============================================
create or alter function fn_IsCardExpired(@ExpireDate date)
returns nvarchar(20)
as begin
	if @ExpireDate is null
	 return 'نامشخص'
	if (@ExpireDate < GETDATE())
	 return 'منقضی شده'
	if DATEDIFF(day,@ExpireDate,GETDATE()) < 30
	 return 'در حال انقضا'
	 
	 return'معتبر'
end
go

