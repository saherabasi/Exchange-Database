-- =============================================
-- وضعیت کلی یک وام
-- ورودی: شناسه وام
-- خروجی: تسویه شده / عقب افتاده / در حال پرداخت
-- =============================================
create function fn_GetLoanStatus(@LoanID int)
returns nvarchar(20)
as begin
	
	if not exists (select 1 from CustomerLoanInstallments cli where CustLoanID = @LoanID
	and cli.Status != 'Paid' )
	return 'تسویه شده'

	if exists (select 1 from CustomerLoanInstallments cli where CustLoanID = @LoanID 
	and cli.Status = 'Late')
	return 'عقب افتاده'

	return 'در حال پرداخت'
end
go

-- =============================================
-- جستجوی مشتری با نام یا کد ملی
-- ورودی: عبارت جستجو
-- خروجی: جدول مشتریان منطبق
-- =============================================
create function fn_SearchCustomer(@SearchTerm nvarchar(30))
returns table
as return(
	select c.CustomerID,c.FirstName,c.LastName,c.NationalCode from Customers c
	where FirstName like '%' + @SearchTerm + '%'
	or
	LastName like '%' + @SearchTerm + '%'
	or
	NationalCode like '%' + @SearchTerm + '%'
)
