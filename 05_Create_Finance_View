-- =============================================
-- جزئیات اقساط وام مشتریان حضوری
-- شامل: شماره قسط + تاریخ سررسید + مبلغ + وضعیت + روزهای تأخیر
-- =============================================
CREATE OR ALTER VIEW [finance].[Vw_CustLoanInstallmentDetails]
AS
SELECT 
    cli.CustLoanID,
    a.AccountNumber,
    c.FirstName + ' ' + c.LastName AS CustomerName,
    c.NationalCode,
    cl.AmountLoan,
    cl.InstatementCount,
    cli.InstallmentNumber,
    cli.DueDate,
    cli.Amount,
    cli.PaidDate,
    cli.Status,
    CASE 
        WHEN cli.Status = 'Late' THEN DATEDIFF(DAY, cli.DueDate, GETDATE())
        ELSE 0
    END AS DaysLate,
    cli.Description
FROM
    CustomerLoanInstallments cli
    INNER JOIN CustomerLoans cl ON cli.CustLoanID = cl.CustLoanID
    INNER JOIN Accounts a ON cl.AccountID = a.AccountID
    INNER JOIN Customers c ON a.CustomerID = c.CustomerID;
GO

-- =============================================
-- جزئیات اقساط وام کاربران سایت
-- شامل: شماره قسط + تاریخ سررسید + مبلغ + وضعیت + روزهای تأخیر
-- =============================================
CREATE OR ALTER VIEW [finance].[Vw_UserLoanInstallmentDetails]
AS
SELECT 
    uli.UserLoanID,
    w.WalletID,
    u.FirstName + ' ' + u.LastName AS UserName,
    u.Email,
    ul.AmountLoan,
    ul.InstatementCount,
    uli.InstallmentNumber,
    uli.DueDate,
    uli.Amount,
    uli.PaidDate,
    uli.Status,
    CASE 
        WHEN uli.Status = 'Late' THEN DATEDIFF(DAY, uli.DueDate, GETDATE())
        ELSE 0
    END AS DaysLate,
    uli.Description
FROM 
    UserLoanInstallments uli
    INNER JOIN UserLoans ul ON uli.UserLoanID = ul.UserLoanID
    INNER JOIN Wallets w ON ul.WalletID = w.WalletID
    INNER JOIN Users u ON w.UserID = u.UserID;
GO

-- =============================================
-- گزارش اقساط عقب افتاده (مشتریان + کاربران)
-- شامل: نوع مشتری + نام + شماره قسط + مبلغ + روزهای تأخیر
-- =============================================
CREATE OR ALTER VIEW [finance].[Vw_LateInstallment]
AS 
SELECT 
    'مشتریان حضوری' AS CustomerType,
    vc.CustLoanID AS LoanID,
    vc.CustomerName AS FullName,
    vc.InstallmentNumber,
    vc.DueDate,
    vc.Amount,
    vc.DaysLate
FROM 
    finance.Vw_CustLoanInstallmentDetails vc
WHERE 
    vc.Status = 'Late'

UNION ALL

SELECT 
    'کاربران سایت' AS CustomerType,
    vu.UserLoanID AS LoanID,
    vu.UserName AS FullName,
    vu.InstallmentNumber,
    vu.DueDate,
    vu.Amount,
    vu.DaysLate
FROM 
    finance.Vw_UserLoanInstallmentDetails vu 
WHERE 
    vu.Status = 'Late';
GO

