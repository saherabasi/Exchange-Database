create   view [dbo].[Vw_CustomerBalanceSummary]
as
select 
ad.CustomerID,
ad.FullName,
ad.NationalCode,
count(ad.AccountID) as AccountCount,
sum(case when ad.Currency = 'USD' then ad.Balance else 0 end) as USDBalance,
sum(case when ad.currency = 'IRR' then ad.balance else 0 end) as IRRBalance,
sum(case when ad.currency = 'EUR' then ad.balance else 0 end) as EURBalance,
Format(GETDATE(),'yyyy/mm/dd') as ReportDate
from Vw_AccountDetails ad
group by 
ad.CustomerID,
ad.FullName,
ad.NationalCode
GO
create   view [dbo].[Vw_ActiveBranch]
as
select 
b.BranchID,
b.BranchName,
b.PhoneNumber,
b.Address,
case when e.EmployeeID is not null then'دارای مدیر'
else 'فاقد مدیر'
end 'ManagerStatus',
e.EmployeeID,
e.FirstName + ' ' + e.LastName as ManagerName,
e.NationalCode,
e.Possition
from
Branchs b
left join 
Employees e on b.ManagerID = e.EmployeeID
where b.IsActive = 1
GO
create   view [dbo].[Vw_CustomerCards]
as
select 
c1.CardID,
c1.CardNumber,
c1.ExpireDate,
case 
 when c1.ExpireDate is null then 'نامشخص'
 when c1.ExpireDate < GETDATE() then 'منقضی شده'
 when DATEDIFF(DAY,GETDATE(),c1.ExpireDate) <= 30 then 'در حال انقضا'
 else 'معتبر'
end'ExpireStatus',
a.AccountNumber,
a.Balance,
a.Currency,
c.FirstName + ' ' + c.LastName as CustomerName,
c.NationalCode,
c.CustomerType,
c.PhoneNumber
from Cards c1
inner join 
Accounts a on c1.AccountID = a.AccountID
inner join 
Customers c on a.CustomerID = c.CustomerID
GO
create   view [dbo].[Vw_CustomerFullInfo]
as 
select c.CustomerID,
c.FirstName + ' ' + c.LastName as FullName,
c.NationalCode,
c.PhoneNumber,
c.Email,
c.Gender as GenderCode,
case 
 when c.Gender = 'm' then 'مرد'
 when c.Gender = 'f' then 'زن'
end'GenderName',
c.IsVerified,
case 
 when c.IsVerified = 1 then 'تایید شده'
 when c.IsVerified = 0 then 'در انتظار'
 when c.IsVerified is null then 'نامشخص'
end 'VerificationStatus',
c.VerificationDate,
c.CustomerType,
a.AccountNumber,
case 
 when a.AccountNumber is not null then 'دارای حساب'
 else 'بدون حساب'
end 'AccountStatus',
a.Balance,
a.CreateDate as AcountCreateDate
from Customers c
left join 
Accounts a on c.CustomerID = a.CustomerID
GO
create   view [dbo].[Vw_DepartmentInfo]
as
select 
dp.DepartmentID,
dp.DepartmentName,
dp.PhoneNumber,
dp.Email,
dp.Address,
c.CountryName,
case 
 when c.CountryID is not null then 'دارای کشور'
 else 'فاقد کشور'
end 'CountryStatus',
c1.CityName,
case 
 when c1.CityID is not null then 'دارای شهر'
 else 'فاقد شهر'
end 'CityStatus'
from 
Departments dp
left join 
Countries c on dp.CountryID = c.CountryID
left join Cities c1 on dp.CityID = c1.CityID
GO
create   view [dbo].[Vw_EmployeesList]
as
select 
e.EmployeeID,
e.FirstName + ' ' + e.LastName as FullName ,
e.NationalCode,
e.Possition,
e.HireDate,
e.Salary,
case when b.BranchName is not null then b.BranchName 
else 'برای کارمند شعبه ای وجود ندارد'
end 'BranchStatus',
