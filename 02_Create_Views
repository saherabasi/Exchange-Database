create   view [dbo].[Vw_Userwallet]
as
select 
w.WalletID,
w.Balance,
case
 when w.Balance > 0 then 'مثبت'
 when w.Balance < 0 then 'منفی'
 else 'صفر'
end 'BalanceStatus',
w.CreateDate,
u.FirstName + ' ' +u.LastName as FullName,
u.Email,
u.PhoneNumber
from Wallets w
inner join 
Users u on w.UserID = u.UserID
