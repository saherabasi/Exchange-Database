create view [dbo].[Vw_CustLoanInstallmentDetails]
as
select 
cli.CustLoanID,
a.AccountNumber,
c.FirstName + ' ' + c.LastName as CustomerName,
c.NationalCode,
cl.AmountLoan,
cl.InstatementCount,
cli.InstallmentNumber,
cli.DueDate,
cli.Amount,
cli.PaidDate,
cli.Status,
case 
 when cli.Status = 'Late' then DATEDIFF(DAY,cli.DueDate,GETDATE())
 else 0
end 'DaysLate',
cli.Description
from
CustomerLoanInstallments cli
inner join 
CustomerLoans cl on cli.CustLoanID = cl.CustLoanID
inner join 
Accounts a on cl.AccountID = a.AccountID
inner join 
Customers c on a.CustomerID = c.CustomerID

GO
create view [dbo].[Vw_UserLoanInstallmentDetails]
as
select 
uli.UserLoanID,
w.WalletID,
u.FirstName + ' ' + u.LastName as UserName,
u.Email,
ul.AmountLoan,
ul.InstatementCount,
uli.InstallmentNumber,
uli.DueDate,
uli.Amount,
uli.PaidDate,
uli.Status,
case 
 when uli.Status = 'Late' then DATEDIFF(DAY,uli.DueDate,GETDATE())
 else 0
end 'DaysLate',
uli.Description
from 
UserLoanInstallments uli
inner join 
UserLoans ul on uli.UserLoanID = ul.UserLoanID
inner join 
Wallets w on ul.WalletID = w.WalletID
inner join 
Users u on w.UserID = u.UserID
GO
create view [dbo].[Vw_LateInstallment]
as 
select 
'مشتریان حضوری' as CustomerType,
vc.CustLoanID LoanID,
vc.CustomerName FullName,
vc.InstallmentNumber,
vc.DueDate,
vc.Amount,
vc.DaysLate
from Vw_CustLoanInstallmentDetails vc
where vc.status = 'Late'
union all
select 
'کاربران سایت' as CustomerType,
vu.UserLoanID LoanID,
vu.UserName FullName,
vu.InstallmentNumber,
vu.DueDate,
vu.Amount,
vu.DaysLate
from Vw_UserLoanInstallmentDetails vu 
where vu.status = 'Late'
GO
