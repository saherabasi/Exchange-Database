-- =============================================
-- تغییر رمز عبور کاربر
-- اعتبارسنجی نام کاربری و رمز عبور قدیمی
-- رمز جدید با SHA256 و Salt هش و جایگزین می‌شود
-- =============================================
create or alter proc [dbo].[sp_ChangePassword]
@UserName nvarchar(30),
@OldPassword nvarchar(255),
@NewPassword nvarchar(255)

as begin
	set nocount on
	begin try
		begin tran
			declare @salt nvarchar(20) = 'jfb$#^$^ethth&^$%!Y$'
			if exists (select 1 from users where 
			UserName = @UserName and HashPassword = HASHBYTES('sha2_256',@OldPassword + @salt))
			begin
				update users set HashPassword = hashbytes('sha2_256',@NewPassword + @salt)
				where UserName = @UserName
		commit
			select 'رمز عبور با موفقیت تغییر پیدا کرد' as status
			end
			else 
			begin 
				select 'نام کاربری یا رمز عبور اشتباه است' as ErrMassage
				rollback
				return
			end 
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as errmassage
	end catch
end
