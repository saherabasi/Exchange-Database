-- =============================================
-- برداشت وجه از حساب بانکی
-- اعتبارسنجی وجود حساب و موجودی کافی
-- ثبت تراکنش برداشت و کسر از موجودی حساب
-- =============================================
create or alter proc [dbo].[sp_WithdrawFromAccount]
@AccountID int,
@Amount decimal(18,2)
as begin
	set nocount on
	begin try
		begin tran
			if not exists (select 1 from Accounts where AccountID = @AccountID)
				begin
					select 'حسابی یافت نشد' as errormassage
					rollback
					return
				end

			if exists (select 1 from Accounts where @Amount > Balance)
				begin
					select 'موجودی کافی نمی باشد' as errormassage
					rollback
					return
				end
			else
				begin
					update Accounts set Balance -= @Amount where AccountID = @AccountID

					insert into Transactions(AccountID,Amount,TransactionType,TransactionDate,
					ExchangeRateID,CommissionAmount,Profit,IPAddress)
					values(@AccountID,@Amount,'Withdraw',getdate(),null,null,null,null)
		commit
					select 'مبلغ با موفقیت از حساب برداشت شد' as status
				end
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as ERRORMESSAGE
	end catch

end
GO

-- =============================================
-- بروزرسانی نرخ ارز
-- نرخ قدیمی را غیرفعال و نرخ جدید را ثبت می‌کند
-- ثبت در ExchangeRateLog با ActionType = 'Updated'
-- =============================================
create or alter proc [dbo].[sp_UpdateExchangeRate]
@FromCurrency nvarchar(20),
@ToCurrency nvarchar(20),
@NewRate decimal(18,2),
@DoneBy nvarchar(20) = 'System'
as begin 
	set nocount on
	begin try
		begin tran
			if not exists (select 1 from ExchangeRates er where er.FromCurrency = @FromCurrency and er.ToCurrency = @ToCurrency)
				begin 
					select 'ارز های وارد شده وجود ندارد' as errmassage 
					rollback
					return
				end
			else
				begin
					declare @LastRate decimal(18,2) = (select dbo.fn_GetExchangeRate(@FromCurrency,@ToCurrency))
					update ExchangeRates set IsActive = 0
					where FromCurrency = @FromCurrency and ToCurrency = @ToCurrency and Rate = @LastRate

					insert into ExchangeRates(FromCurrency,ToCurrency,Rate,RateDate,IsActive)
					values(@FromCurrency,@ToCurrency,@NewRate,GETDATE(),default)

					declare @ExchangeRateID int = scope_identity()
					insert into ExchangeRateLog(ExchangeRateID,FromCurrency,ToCurrency,OldRate,NewRate,ActionType,DoneBy,LogDate)
					values(@ExchangeRateID,@FromCurrency,@ToCurrency,@LastRate,@NewRate,'Updated',@DoneBy,default)

		commit
					select 'آپدیت نرخ ارز با موفقیت انجام شد' as status
			end


	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as errmassage
	end catch
end
go

-- =============================================
-- علامت‌گذاری اعلان به عنوان خوانده شده
-- =============================================
create or alter proc [dbo].[sp_MarkNotificationRead]
@NotificationID int
as begin
	set nocount on
	if exists (select 1 from Notifications where NotificationID = @NotificationID)
	begin
		update Notifications set IsRead = 1 where NotificationID = @NotificationID
	end

	else begin select 'اعلانی با شناسه زیر یافت نشد' as errmassage end
end
