-- مسدود کردن کارت بانکی
-- وضعیت کارت را به 'Block' تغییر می‌دهد
-- =============================================
create or alter proc sp_BlockCard
@CardID int
as begin
	begin try
		begin tran
			if exists (select 1 from cards where CardID = @CardID)
			begin
				declare @CardNumber nvarchar(50),@AccountID int
				select @CardNumber = c.CardNumber ,@AccountID = c.AccountID from Cards c where CardID = @CardID
				update cards set Status = 'Block' where CardID = @CardID
				insert into CardLog(CardID,CardNumber,AccountID,ActionType,LogDate)
				values(@CardID,@CardNumber,@AccountID,'Block',GETDATE())
		commit
			end

			else begin select 'کارتی با شناسه وارد شده وجود ندارد' as errmassage end 

	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as errmassage
	end catch
end
