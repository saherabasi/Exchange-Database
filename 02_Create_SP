-- =============================================
-- بروزرسانی نرخ ارز
-- نرخ قدیمی را غیرفعال و نرخ جدید را ثبت می‌کند
-- =============================================
create or alter proc sp_UpdateExchangeRate
@FromCurrency nvarchar(20),
@ToCurrency nvarchar(20),
@NewRate decimal(18,2),
@DoneBy nvarchar(20) = 'System'
as begin 
	begin try
		begin tran
			if exists (select 1 from ExchangeRates er 
			where er.FromCurrency = @FromCurrency and er.ToCurrency = @ToCurrency)
			begin
				declare @LastRate decimal(18,2) = (select dbo.fn_GetExchangeRate(@FromCurrency,@ToCurrency))
				update ExchangeRates set IsActive = 0
				where FromCurrency = @FromCurrency and ToCurrency = @ToCurrency and Rate = @LastRate

				insert into ExchangeRates(FromCurrency,ToCurrency,Rate,RateDate,IsActive)
				values(@FromCurrency,@ToCurrency,@NewRate,GETDATE(),default)

				declare @ExchangeRateID int = scope_identity()
				insert into ExchangeRateLog(ExchangeRateID,FromCurrency,ToCurrency,OldRate,NewRate,ActionType,DoneBy,LogDate)
				values(@ExchangeRateID,@FromCurrency,@ToCurrency,@LastRate,@NewRate,'Updated',@DoneBy,default)

		commit
			end

			else begin select 'ارز های وارد شده وجود ندارد' as errmassage end
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as errmassage
	end catch
end
go

