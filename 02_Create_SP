-- =============================================
-- انتقال وجه بین دو حساب یک مشتری
-- چک می‌کند هر دو حساب مال یک مشتری و هم‌ارز باشند
-- =============================================
create proc sp_TransferMoney
@FromAccountID int,
@ToAccountID int,
@Amount decimal(18,2)
as begin
	begin try
		begin tran

			if exists (select 1 from Accounts where AccountID = @FromAccountID)
			and exists (select 1 from Accounts where AccountID = @ToAccountID) 

			begin
			declare @OrginID int = (select CustomerID from Accounts where AccountID = @FromAccountID)
			declare @DestID int = (select CustomerID from Accounts where AccountID = @ToAccountID)
			declare @FromCurrency int = (select Currency from Accounts where AccountID = @FromAccountID)
			declare @ToCurrency int = (select Currency from Accounts where AccountID = @ToAccountID)
			if (@OrginID = @DestID and @FromCurrency = @ToCurrency)
			begin					  
				declare @balance decimal(18,2) = (select Balance from Accounts where AccountID = @FromAccountID)
				if @balance >= @Amount
				begin
					update Accounts set Balance -= @Amount where AccountID = @FromAccountID
					insert into Transactions(AccountID,Amount,TransactionType,TransactionDate,
					ExchangeRateID,CommissionAmount,Profit,IPAddress)
					values(@FromAccountID,@Amount,'Withdraw',getdate(),null,null,null,null)

					update Accounts set Balance += @Amount where AccountID = @ToAccountID
					insert into Transactions(AccountID,Amount,TransactionType,TransactionDate,
					ExchangeRateID,CommissionAmount,Profit,IPAddress)
					values(@ToAccountID,@Amount,'Deposit',getdate(),null,null,null,null)
		commit
				end
				else begin select 'موجودی حساب شما کافی نیست' as errmassage end
			end
			else begin select 'حساب ها یا نوع ارز ها یکی نیستند' as errmassage end
			end

			else begin select 'یکی از شناسه ها اشتباه است' as errmassage end
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as errmassage
	end catch
end
go

