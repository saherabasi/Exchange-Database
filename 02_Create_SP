create proc [dbo].[sp_DepositToAccount]
@AccountID int,
@Amount decimal(18,2)
as begin
	begin try
		begin tran
			if exists (select 1 from Accounts where AccountID = @AccountID)
				begin
					
					update Accounts set Balance += @Amount where AccountID = @AccountID

					insert into Transactions (AccountID,Amount,TransactionType,TransactionDate,
					ExchangeRateID,CommissionAmount,Profit,IPAddress)
					values(@AccountID,@Amount,'Deposit',getdate(),null,null,null,null)

		commit
			end
			else
			 begin
				select 'حسابی با شماره ای که وارد کردید یافت نشد' as ErrorMassage
			 end
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as ErrorMassage
	end catch

end
