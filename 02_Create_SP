-- =============================================
-- انتقال وجه بین دو حساب یک مشتری
-- اعتبارسنجی وجود حساب‌ها، یکسان بودن مشتری و ارز، موجودی کافی
-- ثبت دو تراکنش (برداشت + واریز) به‌صورت هم‌زمان
-- =============================================
create or alter  proc [dbo].[sp_TransferMoney]
@FromAccountID int,
@ToAccountID int,
@Amount decimal(18,2)
as begin
	set nocount on
	begin try
		begin tran

			if not exists (select 1 from Accounts where AccountID = @FromAccountID)
				begin 
					select 'شناسه مبدا اشتباه است' as errmassage 
					rollback
					return
				end
			if not exists (select 1 from Accounts where AccountID = @ToAccountID) 
				begin 
					select 'شناسه مقصد اشتباه است' as errmassage 
					rollback
					return
				end

			else
				begin
					declare @OrginID int = (select CustomerID from Accounts where AccountID = @FromAccountID)
					declare @DestID int = (select CustomerID from Accounts where AccountID = @ToAccountID)
					declare @FromCurrency nvarchar(20) = (select Currency from Accounts where AccountID = @FromAccountID)
					declare @ToCurrency nvarchar(20) = (select Currency from Accounts where AccountID = @ToAccountID)

					if (@OrginID != @DestID)
						begin 
							select 'حساب مبدا و مقصد باید برای یک مشتری باشه' as errmassage 
							rollback
							return
						end
					if (@FromCurrency != @ToCurrency)
						begin 
							select 'نوع ارز دو حساب مبدا و مقصد باید یکی باشد' as errmassage 
							rollback
							return
						end

					else
						begin					  
							declare @balance decimal(18,2) = (select Balance from Accounts where AccountID = @FromAccountID)
							if @balance >= @Amount
								begin
									update Accounts set Balance -= @Amount where AccountID = @FromAccountID
									insert into Transactions(AccountID,Amount,TransactionType,TransactionDate,
									ExchangeRateID,CommissionAmount,Profit,IPAddress)
									values(@FromAccountID,@Amount,'Withdraw',getdate(),null,null,null,null)

									update Accounts set Balance += @Amount where AccountID = @ToAccountID
									insert into Transactions(AccountID,Amount,TransactionType,TransactionDate,
									ExchangeRateID,CommissionAmount,Profit,IPAddress)
									values(@ToAccountID,@Amount,'Deposit',getdate(),null,null,null,null)
		commit
									select 'انتقال پول با موفقیت انجام شد' as status
								end
								else 
									begin 
										select 'موجودی حساب شما کافی نیست' as errmassage 
										rollback
										return
									end
						end
				end
				
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as errmassage
	end catch
end
