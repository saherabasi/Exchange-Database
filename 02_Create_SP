create proc [dbo].[sp_PayInstallment]
@InstallmentID int
as begin
	begin try
		begin tran
			if exists (select 1 from CustomerLoanInstallments where InstallmentID = @InstallmentID)
			begin

			declare @Amount decimal(18,2)
			declare @AccountID int

				select 
				@Amount = cli.Amount,
				@AccountID = cl.AccountID
				from CustomerLoanInstallments cli
				inner join 
				CustomerLoans cl on cli.CustLoanID = cl.CustLoanID
				where cli.InstallmentID = @InstallmentID

				if exists (select 1 from Accounts where AccountID = @AccountID and Balance >= @Amount)
				begin

					update Accounts set Balance -= @Amount where AccountID = @AccountID

					insert into Transactions(AccountID,Amount,TransactionType,TransactionDate,
						ExchangeRateID,CommissionAmount,Profit,IPAddress)
						values(@AccountID,@Amount,'Pay Loan',getdate(),null,null,null,null)

					update CustomerLoanInstallments set PaidAmount = @Amount , PaidDate = getdate(),Status = 'Paid',Description = 'قسط وام پرداخت شد خیخیخی'
					where InstallmentID = @InstallmentID
				end
				else
				begin
					select 'موجودی شما کافی نمی باشد' as errmassage
				end
		commit
			end
			else
			begin
				select 'قسطی با شناسه وارد شده وجود ندارد' as errMassage
			end
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as errMassage
	end catch
end
