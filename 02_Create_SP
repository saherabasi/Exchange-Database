create proc [dbo].[sp_WithdrawFromAccount]
@AccountID int,
@Amount decimal(18,2)
as begin
	begin try
		begin tran
			if exists (select 1 from Accounts where AccountID = @AccountID and @Amount <= Balance)
			begin
				update Accounts set Balance -= @Amount where AccountID = @AccountID

				insert into Transactions(AccountID,Amount,TransactionType,TransactionDate,
					ExchangeRateID,CommissionAmount,Profit,IPAddress)
					values(@AccountID,@Amount,'Withdraw',getdate(),null,null,null,null)
				commit
			end

			else if exists (select 1 from Accounts where AccountID = @AccountID and @Amount > Balance)
			begin
			select 'موجودی کافی نمی باشد' as errormassage
			end

			else 
			begin
			select 'حسابی یافت نشد' as errormassage
			end
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as ERRORMESSAGE
	end catch

end
