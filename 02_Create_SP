-- =============================================
-- ورود کاربر به سایت
-- چک کردن نام کاربری و رمز عبور هش شده
-- =============================================
create proc sp_LoginUser
@UserName nvarchar(30),
@Password nvarchar(255)
as begin
	begin try
		begin tran
			declare @salt nvarchar(20) = 'jfb$#^$^ethth&^$%!Y$'
			
			if exists (select 1 from users 
			where UserName = @UserName and HashPassword = HASHBYTES('sha2_256',@Password + @salt))
			begin select 'ورود موفقیت آمیز' as Success 
			
		commit
			end
			else begin select 'نام کاربری یا رمز عبور اشتباه است' as Faild end
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as errmassage
	end catch
end
