-- =============================================
-- ثبت‌نام مشتری حضوری جدید
-- اعتبارسنجی تکراری نبودن کد ملی، ایمیل و شماره تماس
-- =============================================
create or alter proc [dbo].[sp_RegisterCustomers]
@FirstName nvarchar(30),
@LastName nvarchar(30),
@NationalCode bigint,
@Email nvarchar(50),
@PhoneNumber nvarchar(15),
@BirthDate date,
@Gender nvarchar(1)
as begin
	set nocount on
	begin try
		begin tran
			if exists (select 1 from customers where nationalcode = @nationalcode)
				begin
					select 'کد ملی وارد شده قبلا استفاده شده' as ErrMassage 
					rollback
					return
				end 
			if exists (select 1 from customers where Email = @Email)
				begin 
					select 'ایمیل وارد شده قبلا استفاده شده' as ErrMassage 
					rollback
					return
				end 
			if exists (select 1 from customers where PhoneNumber = @PhoneNumber)
				begin
					select 'شماره وارد شده قبلا استفاده شده' as ErrMassage 
					rollback
					return
				end 
			else
				begin
					insert into Customers (FirstName,LastName,NationalCode,Email,PhoneNumber,RegisterDate,BirthDate,Gender,
					IsVerified,VerificationDate,CustomerType)
					values(@FirstName,@LastName,@NationalCode,@Email,@PhoneNumber,GETDATE(),@BirthDate,@Gender,0,null,'Regular')

		commit
					select 'مشتری با موفقیت ثبت شد' as Status
				end
	end try

	begin catch
		select error_message() as error_message
	end catch
end
