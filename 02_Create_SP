create proc [dbo].[sp_OpenAccount]
@CustomerID int,
@Currency nvarchar(20),
@Balance decimal(18,2)
as begin


 begin try
	begin tran
		if exists (select 1 from Customers where CustomerID = @CustomerID)
		begin
		declare @AccNum Nvarchar(30)
		set @AccNum = @Currency + '-' + cast(@CustomerID as nvarchar) + '-' + cast(FORMAT(GETDATE(),'HHmmss') as nvarchar)
		insert into Accounts ([CustomerID],[AccountNumber],[Balance],[Currency],[CreateDate])values(
		@CustomerID,@AccNum,@Balance,@Currency,getdate()
		)
		select SCOPE_IDENTITY() as NewAccountID,@accnum as AccountNumber, 'Success' as Status
	commit
		end
		else
			begin
			select 'مشتری با این آیدی یافت نشد' as ErrorMessage
			end
 end try


 begin catch
  rollback
  select ERROR_MESSAGE() as ErrorMessage
 end catch

end
