-- =============================================
-- ورود کاربر به سایت
-- اعتبارسنجی نام کاربری و رمز عبور با SHA256 + Salt
-- پیام خطای مشترک برای حفظ امنیت
-- =============================================
create or alter proc [dbo].[sp_LoginUser]
@UserName nvarchar(30),
@Password nvarchar(255)
as begin
	set nocount on
	begin try
		begin tran
			
			declare @salt nvarchar(20) = 'jfb$#^$^ethth&^$%!Y$'
			if not exists (select 1 from users where UserName = @UserName and HashPassword = HASHBYTES('sha2_256',@Password + @salt))
				begin 
					select 'نام کاربری یا رمز عبور اشتباه است' as Faild 
					rollback
					return
				end
			else
				begin
					select 'ورود موفقیت آمیز' as Success
		commit
				end
			
				
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as errmassage
	end catch
end
