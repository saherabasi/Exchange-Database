-- =============================================
-- پرداخت یک قسط از وام مشتری
-- اعتبارسنجی وجود وام، شماره قسط و پرداخت نشده بودن قبلی
-- مبلغ قسط از حساب کم و در تراکنش ثبت می‌شود
-- وضعیت قسط به Paid تغییر می‌کند
-- =============================================
create or alter proc sp_PayInstallment

@CustLoanID int,
@InstallmentNumber int

as begin
	set nocount on
	begin try
		begin tran
			if not exists (select 1 from CustomerLoanInstallments where CustLoanID = @CustLoanID)
				begin
					select 'همچین شناسه وامی وجود نداره' as ErrMassage
					rollback
					return
				end
			if not exists (select 1 from CustomerLoanInstallments where CustLoanID = @CustLoanID and InstallmentNumber = @InstallmentNumber )
				begin
					select 'همچین قسطی وجود نداره' as ErrMassage
					rollback
					return
				end
			if exists (select 1 from CustomerLoanInstallments where CustLoanID = @CustLoanID and InstallmentNumber = @InstallmentNumber and Status = 'Paid')
				begin
					select 'این قسط قبلا پرداخت شده' as ErrMassage
					rollback
					return
				end
			else
				begin
					declare @balance decimal(18,2)
					declare @accountID int
					select @accountID = cl.AccountID ,@balance= a.Balance from CustomerLoans cl
					inner join
					Accounts a on cl.AccountID = a.AccountID
					where cl.CustLoanID = @CustLoanID

					declare @eachAmount decimal(18,2) = (select Amount from CustomerLoanInstallments where InstallmentNumber = @InstallmentNumber)
					if (@balance >= @eachAmount)
						begin
							update Accounts set Balance -= @eachAmount where AccountID = @accountID
							
							insert into Transactions(AccountID,Amount,TransactionType,TransactionDate,
							ExchangeRateID,CommissionAmount,Profit,IPAddress)
							values(@AccountID,@eachAmount,'Pay Loan',getdate(),null,null,null,null)
						
							update CustomerLoanInstallments set PaidAmount = @eachAmount , PaidDate = getdate(),Status = 'Paid',Description = 'قسط وام پرداخت شد خیخیخی'
							where CustLoanID = @CustLoanID and InstallmentNumber = @InstallmentNumber
		commit
							select 'قسط مورد نظر با موفقیت پرداخت شد' as Status
						end
					else 
						begin
							select 'موجودی کافی نمی باشد' as ErrMassage
							rollback
							return
						end
				end
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as errMassage
	end catch

end
