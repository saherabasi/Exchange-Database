create   proc [dbo].[sp_IssueCustomerLoan]
@AccountID int,
@Amount decimal(18,2),
@instatmentCount int,
@Currency nvarchar(20)
as begin

	begin try

		begin tran
			
			if exists (select 1 from Accounts where AccountID = @AccountID)
			begin
				declare @IntresteLoanPercent decimal(18,2) = 23

				update Accounts set Balance += @Amount where AccountID = @AccountID and Currency = @Currency
				insert into Transactions (AccountID,Amount,TransactionType,TransactionDate,
					ExchangeRateID,CommissionAmount,Profit,IPAddress)
					values(@AccountID,@Amount,'Loan Deposit',getdate(),null,null,null,null)

				insert into CustomerLoans(AccountID,AmountLoan,IntresteLoan,InstatementCount,LoanDate,Status)values(
				@AccountID,@Amount,@IntresteLoanPercent,@instatmentCount,GETDATE(),'Active')

				declare @LoanID int
				set @LoanID = SCOPE_IDENTITY()
				declare @intrest decimal(18,2) = ( @Amount * @IntresteLoanPercent )/100
				declare @LoanWithintrest decimal(18,2) = @Amount + @intrest
				declare @EachAmount decimal(18,2) = @LoanWithintrest / @instatmentCount
				declare @num int = 1
				while (@num <= @instatmentCount)
				begin
					insert into CustomerLoanInstallments(CustLoanID,InstallmentNumber,DueDate,Amount,PaidAmount,
					PaidDate,Status,Description)
					values(@LoanID,@num,dateadd(MONTH,@num,GETDATE()),@EachAmount,0,null,'pending','وامی با بهره 23 درصد')
					set @num += 1
				end
		commit

			end

			else
			begin
				select 'حسابی با این ارز یافت نشد' as errMassage
			end

	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as err_mass
	end catch

end
