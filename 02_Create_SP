create proc [dbo].[sp_ExchangeCurrency]

@FromAccountID int ,
@ToAccountID int ,
@Amount decimal(18,2)

as begin
	begin try
		begin tran
		--------------------------------------------------------------------------
			if exists (select 1 from Accounts where AccountID = @FromAccountID)
			and                                                                                                            --چک کردن اینکه ایدی حسابهای داده شده درون جدول موجود هست یا نه
			exists (select 1 from Accounts where AccountID = @ToAccountID)
		--------------------------------------------------------------------------

			begin                                                                                                          --توضیحات تکمیلی من باید برای اینکه بدونم کدوم یک از مقادیر ستون ریت مال این مسئلس باید باید اسم ارزهای اکانت مبدا و مقصد رو در متغییر ذخیره کنم که که بعدا در جدول اکسچنج ریت شرط هایی رو بزارم که اون ریتی رو نشون بده که فرام کارنسیش و تو کارنسیش از اکانت های مبدا و مقصد بیاد
				declare @FromCurrency nvarchar(20) = (select Currency from Accounts where AccountID = @FromAccountID)      --اسم ارزی که درون این اکانت هست رو میریزه توی متغییر
				declare @ToCurrency nvarchar(20) = (select Currency from Accounts where AccountID = @ToAccountID)          --اسم ارزی که درون این اکانت هست رو میریزه توی متغییر
				declare @ExchangeRateID int                                                                                --برای پر کردن جدول ترنزکشن این ستون لازمه
				declare @rate decimal(18,2)                                                                                --برای نرخ ارزه


				select top(1) @rate = rate,@ExchangeRateID = ExchangeRateID from ExchangeRates
				where FromCurrency = @FromCurrency and ToCurrency = @ToCurrency and IsActive = 1 order by RateDate desc    --پر کردن متغییر های ریت و اکسچنج ریت ایدی به شرط اینکه همون ریتی انتخاب بشه که نام ارز ها برابر با اکانت های مبدا و مقصد باشه
				if @rate is null
				begin
					SELECT 'نرخ تبدیلی برای این ارزها یافت نشد' AS errMessage;
					return
				end

			    declare @Balance decimal(18,2) = (select Balance from Accounts where AccountID = @FromAccountID)           -- چک میشه که مبلغی که وارد شده در حساب مبدا موجود هست یا خیر
				if (@Amount <= @Balance)
				begin

					declare @Commision decimal(5,2) = 0.5  --کمیسیون
					declare @TotalAmount decimal(18,2) = (@Amount * @rate) --قیمتی که میخاد ارسال بشه
					declare @profit decimal(18,2) = (@TotalAmount * @Commision)/ 100 --سود صرافی
					declare @finalAmount decimal(18,2) = (@TotalAmount - @profit)  --مقداری که دریافت میکنه

					update Accounts set Balance -= @Amount where AccountID = @FromAccountID
					update Accounts set Balance += @finalAmount where AccountID = @ToAccountID

					insert into Transactions (AccountID,Amount,TransactionType,TransactionDate,
					ExchangeRateID,CommissionAmount,Profit,IPAddress)
					values(@FromAccountID,@Amount,'Exchange',getdate(),@ExchangeRateID,@Commision,null,null)

					insert into Transactions (AccountID,Amount,TransactionType,TransactionDate,
					ExchangeRateID,CommissionAmount,Profit,IPAddress)
					values(@ToAccountID,@finalAmount,'Exchange',getdate(),@ExchangeRateID,@Commision,@profit,null)


		commit
				end
				else 
				begin select 'موجودی کافی نمی باشد' as err 
				end

			end
			else  begin select 'یکی از حساب ها اشتباه می باشد' as err end
	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as err_massage
	end catch

end
