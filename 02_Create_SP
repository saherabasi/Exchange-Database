-- =============================================
-- پرداخت وام به مشتری و ایجاد اقساط خودکار
-- اعتبارسنجی وجود حساب و تطابق ارز
-- مبلغ وام به حساب واریز و اقساط به‌صورت خودکار ایجاد می‌شود
-- =============================================
create or alter proc [dbo].[sp_IssueCustomerLoan]
@AccountID int,
@Amount decimal(18,2),
@instatmentCount int,
@Currency nvarchar(20)
as begin
	set nocount on
	begin try

		begin tran
			
			if not exists (select 1 from Accounts where AccountID = @AccountID)
				begin
					select 'حسابی با این شناسه یافت نشد' as errMassage
					rollback
					return
				end
			if not exists (select 1 from Accounts where Currency = @Currency)
				begin
					select 'نوع ارز وارد شده برای حساب مقصد معتبر نمی باشد' as errMassage
					rollback
					return
				end
			else
				begin
					declare @IntresteLoanPercent decimal(18,2) = 23

					update Accounts set Balance += @Amount where AccountID = @AccountID and Currency = @Currency

					insert into Transactions (AccountID,Amount,TransactionType,TransactionDate,ExchangeRateID,CommissionAmount,Profit,IPAddress)
					values(@AccountID,@Amount,'Loan Deposit',getdate(),null,null,null,null)

					insert into CustomerLoans(AccountID,AmountLoan,IntresteLoan,InstatementCount,LoanDate,Status)
					values(@AccountID,@Amount,@IntresteLoanPercent,@instatmentCount,GETDATE(),'Active')

					declare @LoanID int = SCOPE_IDENTITY()
					declare @intrest decimal(18,2) = dbo.fn_CalcLoanIntrest( @Amount , @IntresteLoanPercent )
					declare @LoanWithintrest decimal(18,2) = @Amount + @intrest
					declare @EachAmount decimal(18,2) = @LoanWithintrest / @instatmentCount

					declare @num int = 1
					while (@num <= @instatmentCount)
					begin
						insert into CustomerLoanInstallments(CustLoanID,InstallmentNumber,DueDate,Amount,PaidAmount,
						PaidDate,Status,Description)
						values(@LoanID,@num,dateadd(MONTH,@num,GETDATE()),@EachAmount,0,null,'pending','وامی با بهره 23 درصد')
						set @num += 1
					end
				end

		commit
				select 'وام به حساب مقصد واریز شد' as Status
				

	end try

	begin catch
		rollback
		select ERROR_MESSAGE() as err_mass
	end catch

end
