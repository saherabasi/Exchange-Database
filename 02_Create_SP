-- =============================================
-- ثبت‌نام کاربر جدید سایت
-- اعتبارسنجی تکراری نبودن ایمیل، شماره تماس، نام کاربری و معتبر بودن شهر
-- رمز عبور با SHA256 و Salt هش می‌شود و کیف پول خودکار ایجاد می‌شود
-- =============================================
create or alter proc [dbo].[sp_RegisterUser]
@CityID int,
@FirstName nvarchar(30),
@LastName nvarchar(30),
@Email nvarchar(50),
@PhoneNumber nvarchar(15),
@Address nvarchar(100),
@UserName nvarchar(30),
@HashPassword nvarchar(255)
as begin
	set nocount on
	begin try
		begin tran

			if exists (select 1 from Users where Email = @Email)
				begin 
					select 'ایمیل وارد شده قبلا استفاده شده' as ErrMassage 
					rollback
					return
				end 
			if exists (select 1 from Users where PhoneNumber = @PhoneNumber)
				begin
					select 'شماره وارد شده قبلا استفاده شده' as ErrMassage 
					rollback
					return
				end 
			if exists (select 1 from Users where UserName = @UserName)
				begin
					select 'نام کاربری وارد شده قبلا استفاده شده' as ErrMassage 
					rollback
					return
				end 
			if @CityID is not null and not exists (select 1 from Cities where CityID = @CityID)
				begin
					begin select 'شهر مورد نظر معتبر نیست' as ErrMassage end 
					rollback
					return
				end

			else begin
				declare @salt nvarchar(20) = 'jfb$#^$^ethth&^$%!Y$'
				declare @HashedPassword nvarchar(255) = hashbytes('SHA2_256',@HashPassword+@salt)
				insert into Users (CityID,FirstName,LastName,Email,PhoneNumber,Address,RegisterDate,UserName,HashPassword)
				values(@CityID,@FirstName,@LastName,@Email,@PhoneNumber,@Address,getdate(),@UserName,@HashedPassword)

				declare @UserID int = scope_identity()
				if @UserID is not null (select 1 from Users where UserID = @UserID)
				begin
				insert into Wallets (UserID,Balance,CreateDate) 
				values(@UserID,0,GETDATE())
				end
		commit
				select 'حساب شما با موفقیت ایجاد شد' as status
			end
	end try

	begin catch
		Rollback
		select ERROR_MESSAGE() as ErrMassage
	end catch
end
