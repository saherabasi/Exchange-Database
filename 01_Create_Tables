CREATE TABLE UserLoanInstallments(
    InstallmentID INT IDENTITY(1,1) PRIMARY KEY,
    UserLoanID INT FOREIGN KEY REFERENCES UserLoans(UserLoanID) NOT NULL,
    InstallmentNumber INT NOT NULL, --شماره قسط
    DueDate DATE NOT NULL, --تاریخ سررسید
    Amount DECIMAL(18,2) NOT NULL, --مبلغ این قسط
    PaidAmount DECIMAL(18,2) DEFAULT 0,--مبلغ پرداخت شده
    PaidDate DATETIME NULL,--تاریخ پرداخت
    Status NVARCHAR(20) DEFAULT 'Pending', --Pending, Paid, Late, Partial
    Description NVARCHAR(200) NULL
)

CREATE TABLE CustomerLoanInstallments(
    InstallmentID INT IDENTITY(1,1) PRIMARY KEY,
    CustLoanID INT FOREIGN KEY REFERENCES CustomerLoans(CustLoanID) NOT NULL,
    InstallmentNumber INT NOT NULL, --شماره قسط
    DueDate DATE NOT NULL,--تاریخ سررسید
    Amount DECIMAL(18,2) NOT NULL,--مبلغ این قسط
    PaidAmount DECIMAL(18,2) DEFAULT 0,--مبلغ پرداخت شده
    PaidDate DATETIME NULL,--تاریخ پرداخت
    Status NVARCHAR(20) DEFAULT 'Pending', --Pending, Paid, Late, Partial
    Description NVARCHAR(200) NULL
)

CREATE TABLE CustomerLoans(
    CustLoanID INT IDENTITY PRIMARY KEY,
    AccountID INT REFERENCES Accounts(AccountID),
    AmountLoan DECIMAL(18,2),
    IntresteLoan DECIMAL(18,2),
    InstatementCount INT,
    LoanDate DATETIME DEFAULT GETDATE(),
    Status NVARCHAR(20) DEFAULT 'Active'
);
