create table Customers (
CustomerID int primary key identity,
FirstName nvarchar(30),
LastName nvarchar(30),
NationalCode bigint,
Email nvarchar(50),
PhoneNumber nvarchar(15),
RegisterDate datetime
)
create table Accounts(
AccountID int identity primary key,
CoustomerID int references Customers(CustomerID),
AccountNnumber nvarchar(30) unique,
Balance decimal(18,2),
Currency nvarchar(20),
CreateDate datetime default getdate()
)

create table Transactions(
TransactionID int identity primary key,
AccountID int references Accounts(AccountID),
Amount decimal (18,2),
TransactionType nvarchar(20),
TransactionDate datetime default getdate(),

)

create table ExchangeRates(
ExchangeRateID int identity primary key,
FromCurrency nvarchar(20),
ToCurrency nvarchar(20),
Rate decimal(18,2)
)
create table Currensies(
CurrencyID int identity primary key,
CurrencyName nvarchar(20),
CurrencyCode nvarchar(10)
)

create table Branchs(
BranchID int identity primary key,
BranchName nvarchar(30),
Address nvarchar(100)
)

create table Employees(
EmployeeID int identity primary key,
BranchID int references Branchs(BranchID),
FirstName nvarchar(30),
LastName nvarchar(30),
NationalCode bigint,
Possition nvarchar(30),
Email nvarchar(50),
PhoneNumber nvarchar(15),
HireDate datetime default getdate()
)

create table Cards(
CardID int identity primary key,
CardNumber nvarchar(50) unique,
AccountID int references Accounts(AccountID),
ExpireDate date,

)

create table Loans(
LoanID int identity primary key,
AccountID int references Accounts(AccountID),
AmountLoan decimal(18,2),
IntresteLoan decimal(18,2),
InstatementCount int
)

create table Checks(
CheckID int identity primary key,
AccountID int references Accounts(AccountID),
AmountCheck decimal(18,2),
CheckNumber nvarchar(50),
IssueDate datetime
)

create table Countries(
CountryID int identity primary key,
CountryName  nvarchar(30)
)

create table Cities(
CityID int identity primary key,
CityName  nvarchar(30),
CountryID int references Countries(CountryID),

)

create table Users (
UserID int identity primary key,
CityID int references Cities(CityID),
FirstName nvarchar(30),
LastName nvarchar(30),
Email nvarchar(50),
PhoneNumber nvarchar(15),
Address nvarchar(100),
RegisterDate datetime default getdate()
)

alter table Users add HashPassword nvarchar(30)


create table Wallets(
WalletID int identity primary key,
UserID int references Users(UserID),
Balance decimal(18,2),
CreateDate datetime default getdate()
)

create table UserSessions(
UserSessionID int identity primary key,
UserID int references Users(UserID),
StartSession datetime,
EndSession datetime
)

create table UserConfirmCodes(
UserConfirmCodeID int identity primary key,
UserID int references Users(UserID),
Code int,
ExpireDate datetime
)

create table Roles(
RoleID int identity primary key,
RoleName nvarchar(30)
)


create table UserRoles(
UserRoleID int identity primary key,
UserID int references Users(UserID),
RoleID int references Roles(RoleID)
)

create table UserLog (
UserLogID int identity primary key,
UserID int references Users(UserID),
CityID int references Cities(CityID),
FirstName nvarchar(30),
LastName nvarchar(30),
UserName nvarchar(30),
HashPassword nvarchar(30),
Email nvarchar(50),
PhoneNumber nvarchar(15),
Address nvarchar(100),
createDate datetime default getdate()
)

create table Departments(
DepartmentID int identity primary key,
DepartmentName nvarchar(30),
PhoneNumber nvarchar(50),
Address nvarchar(150),
Email nvarchar(30),
CityID int references Cities(CityID),
CountryID int references Countries(CountryID),
)

create table Notifications(
NotificationID int identity primary key,
UserID int references Users(UserID),
DepartmentID int references Departments(DepartmentID),
Title nvarchar(20),
Description nvarchar(100),
CreateDate datetime default getdate(),
IsRead bit default 0
)
use Exchange

create table CurrencyTypes(
CurrencyTypeID int identity primary key,
CurrencyImages varbinary(max),
Symbol nvarchar(20),
Formatstring nvarchar(50),
