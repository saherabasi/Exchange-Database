)

create table TransactionBalances(
TransactionBalanceID int identity primary key,
CoustomerID int references Customers(CustomerID),
DepartmentID int references Departments(DepartmentID),
CurrencyTypeID int references CurrencyTypes(CurrencyTypeID),
Amount decimal(18,2),
Createdate datetime ,
LastCreatedate datetime ,

)

alter table Transactions add ExchangeRateID int references ExchangeRates(ExchangeRateID)

create table DepartmentTransactions(
DepartmentTransactionID int identity primary key,
